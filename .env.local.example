# ========================
# Clerk Authentication (Required for Google Login)
# ========================
# 1. Go to https://dashboard.clerk.com/ and create an account
# 2. Create a new application
# 3. In the dashboard, go to API Keys and copy the "Publishable Key"
# 4. Enable Google as a social provider in Clerk Dashboard → Social Providers
# 5. Set the key below (remove the placeholder and use your real key)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_REAL_KEY_HERE

# ========================
# Remove.bg API (Already configured in Cloudflare Pages Dashboard)
# ========================
# The REMOVE_BG_API_KEY is stored as a Cloudflare Pages secret
# Do NOT add it here
